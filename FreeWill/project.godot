"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
text/input_action="dialogic_default_action"
variables={}
glossary/default_case_sensitive=true
text/autocolor_names=false
layout/end_behaviour=0
text/autoadvance_per_word_delay=0.01

